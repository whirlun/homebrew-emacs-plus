       CGContextSetTextMatrix (context, atfm);
       CGContextSetTextPosition (context, text_position.x, text_position.y);
 
+      /* Apply glow (neon shadow) effect if face has it enabled.
+	 use additive blending (PlusLighter) and draw the text
+	 in the glow color with a CG shadow multiple times.  Additive
+	 blending accumulates light so repeated passes intensify the
+	 halo without making letters appear thicker.  Then draw the
+	 final sharp text on top with normal blending.  */
+      if (face->glow_p && face->glow_radius > 0 && s->hl != DRAW_CURSOR)
+	{
+	  CGColorRef glow_cgcolor = get_cgcolor (face->glow_color);
+	  CGSize offset = CGSizeMake (0, 0);
+
+	  CGContextSetBlendMode (context, kCGBlendModePlusLighter);
+
+	  for (int pass = 0; pass < face->glow_intensity; pass++)
+	    {
+	      CGContextSaveGState (context);
+	      CGContextSetShadowWithColor (context, offset,
+					   (CGFloat) face->glow_radius,
+					   glow_cgcolor);
+	      CGContextSetFillColorWithColor (context, glow_cgcolor);
+	      CGContextSetTextPosition (context, text_position.x,
+				        text_position.y);
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 1070
+	      if (macfont_info->color_bitmap_p
+#if MAC_OS_X_VERSION_MIN_REQUIRED < 1070
+		  && CTFontDrawGlyphs != NULL
+#endif
+		  )
+		{ if (len > 0) CTFontDrawGlyphs (macfont_info->macfont, glyphs,
+						  positions, len, context); }
+	      else
+#endif
+		{
+		  CGContextSetFont (context, macfont_info->cgfont);
+		  CGContextSetFontSize (context, font_size);
+		  CGContextShowGlyphsAtPositions (context, glyphs, positions, len);
+		}
+	      CGContextRestoreGState (context);
+	    }
+
+	  CGColorRelease (glow_cgcolor);
+	  CGContextSetBlendMode (context, kCGBlendModeNormal);
+	}
+
+      /* Final pass: draw the sharp text on top (no shadow).  */
+      CGContextSetTextPosition (context, text_position.x, text_position.y);
 #if MAC_OS_X_VERSION_MAX_ALLOWED >= 1070
